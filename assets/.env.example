# ──────────────────────────────────────────────
# SoloSquad Configuration
# `solosquad init` writes this file automatically.
# You can edit it by hand afterwards; re-run `solosquad doctor`
# to verify the changes are picked up.
# ──────────────────────────────────────────────

# 1. Owner info
OWNER_NAME=
OWNER_ROLE=

# 2. Messenger platform (discord / slack / telegram)
#    Multiple platforms: MESSENGER=discord,slack
MESSENGER=discord

# 3. Discord settings (if MESSENGER=discord)
#    Create at: https://discord.com/developers/applications
#    → New Application → Bot → Reset Token
#    Also enable: Bot → Privileged Gateway Intents → MESSAGE CONTENT
DISCORD_TOKEN=your-discord-bot-token-here

# 4. Slack settings (if MESSENGER=slack)
#    Create at: https://api.slack.com/apps
#    → Create New App → OAuth & Permissions → Bot Token (xoxb-…)
#    → Socket Mode → Enable → App-Level Token (xapp-…, scope: connections:write)
#    → Event Subscriptions → Enable → subscribe to message.channels
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_COMMAND_CHANNEL=owner-command

# 5. Telegram settings (if MESSENGER=telegram)
#    Create bot via @BotFather → /newbot
#    Chat ID: send a message to the bot, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy chat.id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# 6. GitHub Personal Access Token (optional — used for auto repo creation)
#    GitHub Settings → Developer settings → PAT → Fine-grained
#    Permissions: repo (read/write), org (read)
GITHUB_TOKEN=

# 7. Local repos path (where product workspaces are stored)
#    macOS/Linux:  /Users/you/repos   or   ~/repos
#    Windows:      C:/Users/you/Documents/solosquad-repos
REPOS_BASE_PATH=./repos

# 8. Timezone (used by scheduler cron)
TZ=Asia/Seoul

# 9. Docker Compose — Claude Code credentials directory on the host
#    Mounted into the container at /root/.claude so the CLI stays authenticated.
#    Default when unset: ${HOME}/.claude (macOS/Linux).
#    Override if your host stores creds elsewhere.
# CLAUDE_AUTH_DIR=/Users/you/.claude
